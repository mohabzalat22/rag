// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "./generated"
}

datasource db {
  provider = "postgresql"
}

model User {
  id      Int    @id @default(autoincrement())
  clerkId String @unique
  name    String
  email   String @unique

  /**
   * relations
   */
  chats Chat[]
}

model Chat {
  id     Int     @id @default(autoincrement())
  title  String?
  token  String  @unique
  userId Int

  /**
   * relations
   */
  user     User      @relation(fields: [userId], references: [id])
  messages Message[]
}

enum Actor {
  USER
  ASSISTANT
}

model Message {
  id      Int    @id @default(autoincrement())
  chatId  Int
  actor   Actor
  message String

  /**
   * relations
   */
  chat Chat @relation(fields: [chatId], references: [id])
}
